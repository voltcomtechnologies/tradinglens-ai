generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USER & AUTH
// ============================================
enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  password      String?      // For credentials provider
  avatar        String?
  role          UserRole     @default(USER)
  status        UserStatus   @default(ACTIVE)
  emailVerified DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  subscriptions Subscription[]
  payments      Payment[]
  progress      CourseProgress[]
  quizResults   QuizResult[]
  analyses      ChartAnalysis[]
  chatMessages  ChatMessage[]
  journal       TradingJournal[]
  leaderboard   LeaderboardEntry[]
  notifications Notification[]
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  tradingStyle    String?  // scalper, day trader, swing trader, position
  experienceLevel String?  // beginner, intermediate, advanced, expert
  preferredPairs  String // JSON array: ["EURUSD", "GBPUSD"]
  timezone        String?
  bio             String?
  phone           String?
  country         String?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// SUBSCRIPTION & BILLING
// ============================================
enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
  TRIAL
}

enum PlanInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String   // "Basic", "Pro", "Elite"
  slug        String   @unique
  description String?
  priceNGN    Int      // Price in NGN (kobo)
  priceUSD    Int      // Price in USD (cents)
  priceEUR    Int?     // Price in EUR (cents)
  priceGBP    Int?     // Price in GBP (cents)
  interval    PlanInterval @default(MONTHLY)
  features    String // JSON array of feature descriptions
  lensAccess  String // JSON array: ["trading", "chart", "edu"]
  maxUsers    Int?     // For team plans
  isPopular   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id              String             @id @default(cuid())
  userId          String
  planId          String
  status          SubscriptionStatus @default(PENDING)
  startDate       DateTime
  endDate         DateTime
  autoRenew       Boolean            @default(true)
  paymentMethod   String?            // paystack, flutterwave
  transactionRef  String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id])
  payments Payment[]
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentProvider {
  PAYSTACK
  FLUTTERWAVE
}

model Payment {
  id             String          @id @default(cuid())
  userId         String
  subscriptionId String?
  amount         Int             // In smallest currency unit
  currency       String          // NGN, USD, EUR, GBP
  provider       PaymentProvider
  providerRef    String?         // Transaction reference from provider
  status         PaymentStatus   @default(PENDING)
  metadata       Json?
  paidAt         DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
}

// ============================================
// COURSES & EDUCATION
// ============================================
model Course {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  coverImage  String?
  level       String   // beginner, intermediate, advanced
  category    String   // technical analysis, fundamentals, psychology, risk management
  isPublished Boolean  @default(false)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  modules    CourseModule[]
  progresses CourseProgress[]
  quizzes    Quiz[]
}

model CourseModule {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  orderIndex  Int      @default(0)
  duration    Int?     // Estimated minutes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course   Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  materials PDFMaterial[]
}

model PDFMaterial {
  id          String   @id @default(cuid())
  moduleId    String
  title       String
  fileUrl     String
  fileSize    Int?     // bytes
  pageCount   Int?
  extractedText String?
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  module CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model CourseProgress {
  id           String   @id @default(cuid())
  userId       String
  courseId     String
  moduleId     String?
  materialId   String?
  progressPct  Int      @default(0) // 0-100
  isCompleted  Boolean  @default(false)
  completedAt  DateTime?
  lastAccessed DateTime @default(now())
  timeSpent    Int      @default(0) // minutes

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Quiz {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  questions   Json     // Array of question objects
  timeLimit   Int?     // minutes
  passScore   Int      @default(70) // percentage
  createdAt   DateTime @default(now())

  course    Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  results   QuizResult[]
}

model QuizResult {
  id        String   @id @default(cuid())
  userId    String
  quizId    String
  score     Int      // percentage
  answers   Json     // User's answers
  passed    Boolean
  timeTaken Int?     // seconds
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

// ============================================
// TRADING LENS - AI CHAT & ANALYSIS
// ============================================
model ChartAnalysis {
  id          String   @id @default(cuid())
  userId      String
  imageUrl    String?  // Uploaded chart image
  pair        String?  // e.g. "EURUSD"
  timeframe   String?  // e.g. "1H", "4H", "D"
  analysisType String  // technical, fundamental, sentiment
  userPrompt  String?
  aiResponse  String
  signals     Json?    // Structured trade signals
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  sessionId String   // Group messages by session
  role      String   // user, assistant, system
  content   String
  lensType  String   // trading, chart, edu
  metadata  Json?    // e.g. image URLs, pair info
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId])
}

// ============================================
// ADMIN CONFIGURATION
// ============================================
model AdminConfig {
  id            String   @id @default(cuid())
  key           String   @unique
  value         String
  category      String   // ai, payment, general
  description   String?
  updatedAt     DateTime @updatedAt
  updatedBy     String?
}

// ============================================
// INNOVATIVE FEATURES
// ============================================
model TradingJournal {
  id          String   @id @default(cuid())
  userId      String
  pair        String
  direction   String   // BUY, SELL
  entryPrice  Float
  exitPrice   Float?
  stopLoss    Float?
  takeProfit  Float?
  lotSize     Float?
  pips        Float?
  profitLoss  Float?
  status      String   // OPEN, CLOSED, CANCELLED
  strategy    String?
  notes       String?
  screenshot  String?
  emotions    String?  // How trader felt
  lessons     String?
  entryDate   DateTime
  exitDate    DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LeaderboardEntry {
  id          String   @id @default(cuid())
  userId      String   @unique
  totalPips   Float    @default(0)
  winRate     Float    @default(0)
  totalTrades Int      @default(0)
  profitFactor Float   @default(0)
  rank        Int      @default(0)
  streak      Int      @default(0)
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String   // trade_alert, course_update, subscription, system
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

// ============================================
// AI PROMPT TEMPLATES
// ============================================
model AIPrompt {
  id          String   @id @default(cuid())
  name        String   @unique
  category    String   // trading, chart, edu
  systemPrompt String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
