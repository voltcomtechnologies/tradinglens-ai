generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// USER & AUTH
// ============================================
enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

model User {
  id            String     @id @default(cuid())
  email         String     @unique
  name          String?
  password      String?
  avatar        String?
  role          UserRole   @default(USER)
  status        UserStatus @default(ACTIVE)
  emailVerified DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts      Account[]
  sessions      Session[]
  profile       Profile?
  subscriptions Subscription[]
  payments      Payment[]
  progress      CourseProgress[]
  quizResults   QuizResult[]
  aiGenerations CourseAiGeneration[]
  analyses      ChartAnalysis[]
  chatMessages  ChatMessage[]
  journal       TradingJournal[]
  leaderboard   LeaderboardEntry[]
  notifications Notification[]
}

model Profile {
  id              String   @id @default(cuid())
  userId          String   @unique
  tradingStyle    String?
  experienceLevel String?
  preferredPairs  String
  timezone        String?
  bio             String?
  phone           String?
  country         String?
  llmProvider     String?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NextAuth models
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================
// SUBSCRIPTION & BILLING
// ============================================
enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PENDING
  TRIAL
}

enum PlanInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

model SubscriptionPlan {
  id          String       @id @default(cuid())
  name        String
  slug        String       @unique
  description String?
  priceNGN    Int
  priceUSD    Int
  priceEUR    Int?
  priceGBP    Int?
  interval    PlanInterval @default(MONTHLY)
  features    String
  lensAccess  String
  maxUsers    Int?
  isPopular   Boolean      @default(false)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id             String             @id @default(cuid())
  userId         String
  planId         String
  status         SubscriptionStatus @default(PENDING)
  startDate      DateTime
  endDate        DateTime
  autoRenew      Boolean            @default(true)
  paymentMethod  String?
  transactionRef String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan     SubscriptionPlan @relation(fields: [planId], references: [id])
  payments Payment[]
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

enum PaymentProvider {
  PAYSTACK
  FLUTTERWAVE
}

model Payment {
  id             String          @id @default(cuid())
  userId         String
  subscriptionId String?
  amount         Int
  currency       String
  provider       PaymentProvider
  providerRef    String?
  status         PaymentStatus   @default(PENDING)
  metadata       Json?
  paidAt         DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id])
}

// ============================================
// COURSES & EDUCATION
// ============================================
model Course {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  description String?
  coverImage  String?
  level       String
  category    String
  isPublished Boolean  @default(false)
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Admin-curated outline for the AI Classroom, plus admin opt-in flag.
  // Stored as JSON so we can later switch to a richer `.maic.zip` blob
  // without a schema migration. Outline format: see src/lib/openmaic.ts.
  // Note: contents ship to the client unredacted — keep this subset to
  // TITLES/DESCRIPTIONS/TOPICS that are already public on Learn landing.
  aiClassroomOutline   Json?
  aiClassroomEnabled   Boolean   @default(false)
  aiClassroomUpdatedAt DateTime?

  modules       CourseModule[]
  progresses    CourseProgress[]
  quizzes       Quiz[]
  aiGenerations CourseAiGeneration[]
}

// Tracks every AI classroom token issuance, used by /api/openmaic-token to
// enforce the daily rate limit (5 per user). courseId is optional so we can
// issue generic multipurpose tokens in the future. Note: userId is required
// for the rate-limit query; courseId FK uses SetNull so deleting a Course
// leaves the audit row intact with a null FK (instead of cascade-deleting
// the audit or blocking the parent delete).
model CourseAiGeneration {
  id        String   @id @default(cuid())
  userId    String
  courseId  String?
  launched  Boolean   @default(false)
  createdAt DateTime  @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course? @relation(fields: [courseId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([courseId, createdAt])
}

model CourseModule {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  orderIndex  Int      @default(0)
  duration    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  course    Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  materials PDFMaterial[]
}

model PDFMaterial {
  id            String   @id @default(cuid())
  moduleId      String
  title         String
  fileUrl       String
  fileSize      Int?
  pageCount     Int?
  extractedText String?
  orderIndex    Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  module CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
}

model CourseProgress {
  id           String    @id @default(cuid())
  userId       String
  courseId     String
  moduleId     String?
  materialId   String?
  progressPct  Int       @default(0)
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?
  lastAccessed DateTime  @default(now())
  timeSpent    Int       @default(0)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

model Quiz {
  id          String   @id @default(cuid())
  courseId    String
  title       String
  description String?
  questions   Json
  timeLimit   Int?
  passScore   Int      @default(70)
  createdAt   DateTime @default(now())

  course  Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  results QuizResult[]
}

model QuizResult {
  id        String   @id @default(cuid())
  userId    String
  quizId    String
  score     Int
  answers   Json
  passed    Boolean
  timeTaken Int?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
}

// ============================================
// TRADING LENS - AI CHAT & ANALYSIS
// ============================================
model ChartAnalysis {
  id           String   @id @default(cuid())
  userId       String
  imageUrl     String?
  pair         String?
  timeframe    String?
  analysisType String
  userPrompt   String?
  aiResponse   String
  signals      Json?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String
  sessionId String
  role      String
  content   String
  lensType  String
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sessionId])
}

// ============================================
// ADMIN CONFIGURATION
// ============================================
model AdminConfig {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  category    String
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?
}

// ============================================
// INNOVATIVE FEATURES
// ============================================
model TradingJournal {
  id         String    @id @default(cuid())
  userId     String
  pair       String
  direction  String
  entryPrice Float
  exitPrice  Float?
  stopLoss   Float?
  takeProfit Float?
  lotSize    Float?
  pips       Float?
  profitLoss Float?
  status     String
  strategy   String?
  notes      String?
  screenshot String?
  emotions   String?
  lessons    String?
  entryDate  DateTime
  exitDate   DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LeaderboardEntry {
  id           String   @id @default(cuid())
  userId       String   @unique
  totalPips    Float    @default(0)
  winRate      Float    @default(0)
  totalTrades  Int      @default(0)
  profitFactor Float    @default(0)
  rank         Int      @default(0)
  streak       Int      @default(0)
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  message   String
  type      String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

// ============================================
// AI PROMPT TEMPLATES
// ============================================
model AIPrompt {
  id           String   @id @default(cuid())
  name         String   @unique
  category     String
  systemPrompt String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
