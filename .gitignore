# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.local
.env.development
.env.production

# vercel
.vercel

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# local dev database (SQLite)
dev.db
dev.db-journal

.vercel
.env*

# ── OpenMAIC subrepo (vendored next to the TradingLens app) ──────────
# node_modules at every nesting level: root openmaic, packages/*, app/, etc.
openmaic/node_modules/
openmaic/packages/*/node_modules/
openmaic/**/dist/
openmaic/**/.next/
openmaic/**/.turbo/
openmaic/**/.cache/
# Build artifacts produced by openmaic's postinstall step.
openmaic/packages/*/lib/
openmaic/packages/*/dist/

# Playwright (e2e visual snapshots)
/e2e/test-results/
/playwright-report/
/playwright/.cache/
# Cached login storage state used by e2e/tests/trading-lens-narrow.spec.ts.
/.auth/
# NOTE: the snapshot baselines themselves live next to the spec file at
#   e2e/tests/trading-lens-narrow.spec.ts-snapshots/
# and ARE committed on purpose so future diffs are detected in PR review.
